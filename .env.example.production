# ===========================================
# Help Desk SaaS - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env.production
# Preencha com seus dados de produção
# ===========================================

# -------------------------------------------
# AMBIENTE
# -------------------------------------------
ENVIRONMENT=production
# development | production

# -------------------------------------------
# SEGURANÇA
# -------------------------------------------
# Gere uma chave secreta com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Senha mestra para acesso ao Painel Master
MASTER_PASSWORD=

# -------------------------------------------
# BANCO DE DADOS (Produção - PostgreSQL)
# -------------------------------------------
# Render PostgreSQL:
#   Dashboard → Database → Copy Internal Database URL
# Neon:
#   Project → Connection String → Copy
# Railway:
#   Variables → DATABASE_URL (automático)

DATABASE_URL=postgresql://user:password@host:port/database

# -------------------------------------------
# BANCO DE DADOS (Desenvolvimento - SQLite)
# -------------------------------------------
# Apenas para testes locais
# DATABASE_URL=sqlite:///databases/master.db

# -------------------------------------------
# DOMÍNIO
# -------------------------------------------
# Domínio principal (produção)
MAIN_DOMAIN=helpdeskhub.com

# URL base para geração de links
BASE_URL=https://helpdeskhub.com

# -------------------------------------------
# UPLOAD
# -------------------------------------------
# Tamanho máximo em bytes (16MB padrão)
MAX_UPLOAD_SIZE=16777216

# Diretório de uploads (produção)
UPLOAD_FOLDER=/tmp/uploads

# -------------------------------------------
# EMAIL (Opcional - Para notificações)
# -------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha
# SMTP_FROM=noreply@helpdeskhub.com

# -------------------------------------------
# LOGS
# -------------------------------------------
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR | CRITICAL

# -------------------------------------------
# PERFORMANCE
# -------------------------------------------
# Número de workers do Gunicorn
GUNICORN_WORKERS=4

# Timeout em segundos
GUNICORN_TIMEOUT=120

# -------------------------------------------
# REDIS (Opcional - Para cache/sessão)
# -------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# -------------------------------------------
# MONITORAMENTO (Opcional)
# -------------------------------------------
# SENTRY_DSN=https://your_sentry_dsn
