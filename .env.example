# Configurações do Help Desk SaaS Multi-Tenant

# Senha mestra para acesso ao Painel Master
MASTER_PASSWORD=Master@2024

# Chave secreta do Flask (altere em produção)
SECRET_KEY=helpdesk_secured_2024_mude_em_producao

# Modo debug (False em produção)
FLASK_DEBUG=True

# Host e porta
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Diretório de bancos de dados (opcional, padrão: ./databases)
# DATABASES_DIR=/caminho/para/databases

# Configurações de upload
MAX_UPLOAD_SIZE=16777216
UPLOAD_FOLDER=static/uploads

# Fuso horário
TIMEZONE=America/Sao_Paulo
